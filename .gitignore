content-factory/Instagram Ready/*
content-factory/Published/*
content-factory/Archive/*
content-factory/Backups/*

!content-factory/RAW/.gitkeep
!content-factory/Enhanced/.gitkeep
!content-factory/Lightroom Ready/.gitkeep
