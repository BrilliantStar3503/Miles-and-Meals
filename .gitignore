# Dependencies and local tooling
node_modules/
.DS_Store

# Runtime content factory state
content-factory/content-factory-state.json
content-factory/Logs/*.ndjson
content-factory/Drafts/*.json

# Creator media and generated assets are local by default.
content-factory/RAW/*
content-factory/Enhanced/*
