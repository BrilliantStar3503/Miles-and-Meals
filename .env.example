# Automation 1 configuration. Copy to .env and adjust as needed.
# .env is git-ignored; never commit real paths containing personal media.

# Root of the production Media Workspace (outside this repository).
AUTOMATION1_MEDIA_ROOT=~/Miles and Meals PH

# Enhancement provider name. Defaults to "cloudinary" (the official Miles &
# Meals Natural Travel Enhancement Profile -- see docs/FEATURES/automation-1.md
# for setup). Set to "passthrough" to copy files unmodified instead (e.g. if
# Cloudinary credentials are not configured yet, or for offline testing).
# Future providers (e.g. "openai", "topaz", "firefly") can be registered
# without changing the automation workflow.
AUTOMATION1_ENHANCEMENT_PROVIDER=cloudinary

# Required for the "cloudinary" provider. Create a free Cloudinary account
# at https://cloudinary.com and copy these from the account dashboard.
# Never commit real values -- this file is a template only.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional. Cloudinary folder used while the photo is briefly hosted for
# enhancement. Defaults to "miles-and-meals/automation1".
CLOUDINARY_UPLOAD_FOLDER=miles-and-meals/automation1

# Optional. Override the Miles & Meals Natural Travel Enhancement Profile's
# Cloudinary transformation string. Leave unset to use the official profile
# defined in src/automation1/providers/enhancement-profile.js.
CLOUDINARY_ENHANCEMENT_TRANSFORMATION=

# Optional. Set to "false" to keep the uploaded copy on Cloudinary after
# enhancement (e.g. for debugging). Defaults to "true" -- the photo is
# deleted from Cloudinary immediately after the enhanced version is
# downloaded, so creator media is not retained on a third-party service.
CLOUDINARY_DELETE_AFTER_DOWNLOAD=true

# Number of files processed concurrently by the processing queue.
AUTOMATION1_QUEUE_CONCURRENCY=2

# Milliseconds to wait before re-checking file size to confirm a candidate
# file has finished writing/syncing before validation passes.
AUTOMATION1_STABILITY_CHECK_MS=300

# Automation 2 configuration.

# Root of the production Media Workspace (outside this repository).
AUTOMATION2_MEDIA_ROOT=~/Miles and Meals PH

# Number of files processed concurrently by the processing queue.
AUTOMATION2_QUEUE_CONCURRENCY=2

# Milliseconds to wait before re-checking file size to confirm an
# Instagram Ready image has finished writing/syncing before validation passes.
AUTOMATION2_STABILITY_CHECK_MS=300
