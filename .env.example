# Automation 1 configuration. Copy to .env and adjust as needed.
# .env is git-ignored; never commit real paths containing personal media.

# Root of the production Media Workspace (outside this repository).
AUTOMATION1_MEDIA_ROOT=~/Miles and Meals PH

# Enhancement provider name. "passthrough" copies the original file
# unmodified. Future providers (e.g. "openai", "topaz", "firefly") can be
# registered without changing the automation workflow.
AUTOMATION1_ENHANCEMENT_PROVIDER=passthrough

# Number of files processed concurrently by the processing queue.
AUTOMATION1_QUEUE_CONCURRENCY=2

# Milliseconds to wait before re-checking file size to confirm a candidate
# file has finished writing/syncing before validation passes.
AUTOMATION1_STABILITY_CHECK_MS=300
